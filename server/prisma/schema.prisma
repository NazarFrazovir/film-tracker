generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String          @id @default(cuid())
  email               String          @unique
  name                String?
  passwordHash        String
  onboardingCompleted Boolean         @default(true)
  watchGoal           Int?
  createdAt           DateTime        @default(now())
  favorites    Favorite[]
  legendary    Legendary[]
  watchlist    WatchlistItem[]
  watched      WatchedItem[]
  customLists  CustomList[]
  tags         Tag[]
  movieTags    MovieTag[]
}

model Favorite {
  id      String   @id @default(cuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tmdbId  Int
  addedAt DateTime @default(now())

  @@unique([userId, tmdbId])
  @@index([userId])
}

model Legendary {
  id      String   @id @default(cuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tmdbId  Int
  addedAt DateTime @default(now())

  @@unique([userId, tmdbId])
  @@index([userId])
}

model WatchlistItem {
  id      String   @id @default(cuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tmdbId  Int
  addedAt DateTime @default(now())

  @@unique([userId, tmdbId])
  @@index([userId])
}

model WatchedItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tmdbId    Int
  watchedAt DateTime?
  rating    Int?
  notes     String?

  @@unique([userId, tmdbId])
  @@index([userId, watchedAt])
}

model CustomList {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    CustomList?      @relation("ListTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  CustomList[]     @relation("ListTree")
  name      String
  emoji     String?
  color     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  items     CustomListItem[]

  @@index([userId])
  @@index([parentId])
}

model CustomListItem {
  id       String     @id @default(cuid())
  listId   String
  list     CustomList @relation(fields: [listId], references: [id], onDelete: Cascade)
  tmdbId   Int
  position Int        @default(0)
  addedAt  DateTime   @default(now())

  @@unique([listId, tmdbId])
  @@index([listId, position])
}

model Tag {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime   @default(now())
  movies    MovieTag[]

  @@unique([userId, name])
  @@index([userId])
}

model MovieTag {
  id      String   @id @default(cuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tmdbId  Int
  tagId   String
  tag     Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  addedAt DateTime @default(now())

  @@unique([userId, tmdbId, tagId])
  @@index([userId, tmdbId])
  @@index([tagId])
}

model CachedMovie {
  tmdbId       Int      @id
  title        String
  originalTitle String?
  overview     String   @default("")
  posterPath   String?
  backdropPath String?
  releaseDate  String?
  voteAverage  Float    @default(0)
  runtime      Int?
  tagline      String?
  genres       String   @default("[]")
  cachedAt     DateTime @default(now())
}